# Verificar GPU
import torch
print("Configuració inicial\n"+"="*40)
print(f"✅ PyTorch version: {torch.__version__}")
print(f"✅ GPU disponible: {torch.cuda.is_available()}")

if torch.cuda.is_available():
   print(f"✅ GPU: {torch.cuda.get_device_name(0)}")

   # Obtener memoria
   props = torch.cuda.get_device_properties(0)
   print(f"✅ Memòria GPU: {props.total_memory / 1e9:.1f} GB")
   print(f"✅ Memòria lliure: {torch.cuda.memory_reserved(0) / 1e9:.1f} GB reservats")

   # Número de GPUs
   print(f"✅ Número de GPUs: {torch.cuda.device_count()}")
else:
    print("❌ No hi ha GPU disponible. El training serà MOLT lent!")

